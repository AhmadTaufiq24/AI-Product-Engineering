{
  "name": "api",
  "type": "module",
  "scripts": {
    "dev": "pnpm with-env tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "pnpm with-env prisma migrate dev",
    "db:generate": "pnpm with-env prisma generate",
    "db:deploy": "pnpm with-env prisma deploy",
    "db:studio": "pnpm with-env prisma studio",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@anvia/memory-prisma": "^0.2.4",
    "@anvia/server": "^0.5.11",
    "@devscale/agent": "workspace:*",
    "@hono/node-server": "^2.0.10",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "hono": "^4.12.31",
    "prisma": "^7.8.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
}